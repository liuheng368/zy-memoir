{
  "name": "zy-memoir",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "钟园幼儿园 2024 届大二班 · 班级回忆录（Vue 3 + CloudBase SPA）",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview --port 4173",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css,md}\"",
    "deploy": "node scripts/deploy.mjs",
    "deploy:fn": "node scripts/deploy.mjs --only fn --skip-build",
    "deploy:static": "node scripts/deploy.mjs --only static",
    "backup": "node scripts/backup.mjs",
    "sign:admin": "node scripts/sign-admin.mjs",
    "sign:admin:env": "node scripts/sign-admin-token.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@cloudbase/js-sdk": "^2.10.0",
    "browser-image-compression": "^2.0.2",
    "pinia": "^2.2.4",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.30.0",
    "npm-run-all2": "^6.2.3",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10"
  },
  "packageManager": "pnpm@9.12.2"
}
